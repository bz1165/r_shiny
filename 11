  sorder1 <- filter(meta1,memname==domain1)$sorder[1] %>% str_to_upper()
  meta2 <- meta1 %>% filter(memname==domain1|
                            (included1 %in% c("ALL","YES","Y") & !(common %in% c('','NO')))|
                            (!(included1 %in% c("NO","")) & str_detect(common,regex('\\b(all|yes|y)\\b',ignore_case=TRUE)))|
                            (!(included1 %in% c("ALL","YES","Y","NO","")) & str_detect(common,regex1)))
  meta3 <- meta2 %>% mutate(var_order=1:nrow(meta2)+if_else(memname==domain1,1e5,0),
                            varname=str_to_upper(varname)) %>%
    select(memname,varname,varlabel,type,length,format,var_order) %>%
    group_by(varname) %>% filter(var_order==min(var_order)) %>% ungroup()
  meta3[meta3$varname=='SUBJID','var_order'] <- meta3[meta3$varname=='USUBJID','var_order']+0.1

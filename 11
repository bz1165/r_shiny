           format_align=str_detect(paste0(Class,'#',format),'^(-none-#[\\$\\d\\.\\s]+|Date#DATE9\\.|POSIXct#DATETIME19\\.|hms#TIME[0-9]?\\.)$'))

  if (!all(indata_content2$type_align)) warning(paste0(
    "Variable type in indata does not align with metadata:\n",
    "Variable\tType\tMetadata\n",
    indata_content2 %>% filter(!type_align) %>% transmute(paste0(varname,"\t",Mode,"\t",type)) %>%
      unlist() %>% str_c(collapse="\n")
    ))

  if (!all(indata_content2$format_align)) warning(paste0(
    "Variable class in indata does not align with metadata format.\n",
    "  If metadata format is DATE9, variable class should be Date.\n",
    "  If metadata format is DATETIME19, variable class should be POSIXct.\n",
    "  If metadata format is TIME*, variable class should be hms.\n",
    "Variable\tClass\tFormat\n",
    indata_content2 %>% filter(!format_align) %>% transmute(paste0(varname,"\t",Class,"\t",format)) %>%
      unlist() %>% str_c(collapse="\n")
    ))

  #sort records
  sorder2 <- sorder1 %>% str_replace_all(sprintf('\\b(%s|DESCENDING)\\b\\s?',str_c(indata_content2$varname,collapse='|')),'') %>% str_trim()
  if (sorder2!='') {
    message(sprintf("Variable %s in metadata sorder(Sort Order), but not in indata.",sorder2))
    if (str_detect(domain1,'^AD')) sorder1 <- sorder1 %>% str_replace_all(sprintf('\\b(%s)\\b\\s?',str_replace_all(sorder2,"\\s","|")),'')
  }
  if (sorder1!='') {
    sorder11 <- sorder1 %>% str_replace_all("\\bDESCENDING\\s+","") %>% str_replace_all("\\s",",indata$")
    sorder12 <- sorder1 %>% str_replace_all("\\bDESCENDING\\s+","@") %>%
      str_replace_all("(?<!@)\\b\\w+","F") %>% str_replace_all("@\\w+","T") %>%
      str_replace_all("\\s+",",")
    expr1 <- sprintf("order(indata$%s,method='radix',decreasing=c(%s),na.last=FALSE)",sorder11,sorder12)
    sorder3n <- eval(parse(text=expr1))
    indata <- indata[sorder3n,]
  }

  #set attributes
  indata_content3 <- indata_content2 %>%
    mutate(format2={format[str_detect(format,'DATE|TIME')]<-str_replace(str_subset(format,'DATE|TIME'),"\\.$","")
                    format[str_detect(format,'^[\\$\\d\\.\\s]+$')]<-NA
                    format},
            tzone=if_else(str_detect(format2,'DATETIME19'),'UTC',NA_character_),
            units=if_else(str_detect(format2,'TIME5'),'secs',NA_character_)) %>%
  arrange(var_order)

  indata2 <- indata %>% select(indata_content3$varname)
  indata2 <- modify2(indata2,indata_content3$varlabel,~ `attr<-`(.x,'label',.y))
  indata2 <- modify2(indata2,indata_content3$format2,~ `attr<-`(.x,'format.sas',if(is.na(.y)) NULL else .y ))
  #indata2 <- modify2(indata2,indata_content3$tzone,~ `attr<-`(.x,'tzone',if(is.na(.y)) NULL else .y ))
  #indata2 <- modify2(indata2,indata_content3$units,~ `attr<-`(.x,'units',if(is.na(.y)) NULL else .y ))
  attr(indata2,'label') <- memlabel1

  indata2
}













#' Initial function to create TFL RTF file.
#'
#' It defines basic layout format, reads info from trakdata.
#' Dependent object defined in _setup.R: st$title00, st$referenc
#' Dependent R package: reporter
#'
#' @param idkey A string from IDKEY column in PDT, indicating the TFL to create
#' @param trakdata Track data file name stored in RA util folder
#'
#' @return a list with three elements: shell, title, footnote.
#'
#' @examples
#' create_report2('PTL001')
#' @export
create_report2 <- function(idkey, trakdata='TrakData.csv') {
  #developed by Zongle, Zimeng, Carlos
  #read trakdata
  TrakData <- read_delim(paste0(st$rautil, trakdata), col_names = TRUE,
                         delim = "<[]>",show_col_types = FALSE, name_repair="universal_quiet",na="")
  # Find the row that matches the given Unique ID
  idkey_row <- TrakData |> dplyr::filter(str_to_upper(`Unique.ID.reference.number`)==str_to_upper(idkey))
  if (nrow(idkey_row)==0) stop(sprintf('IDKEY "%s" does not exist in %s.',str_to_upper(idkey),trakdata))
  if (nrow(idkey_row)>1) stop(sprintf('IDKEY "%s" has more than one line in %s.',str_to_upper(idkey),trakdata))
  # Get output title
  title <- paste(idkey_row$Type,idkey_row$Output.table.number, "(Page [pg] of [tpg])\n",idkey_row$Report.title)|> 
    str_replace_all("\\|", "\n") |> str_glue()
  # Get footnote
  footnote <- idkey_row$Report.footnote|> str_replace_all("\\|", "\n") |> str_glue()
  if (is.na(footnote)||footnote=="") footnote <- character(0)
  # Get output folder path
  folder <- tolower(substring(idkey_row$Output.group,1,3))
  outputfile <- case_when(folder=='eff' ~ st$rprteff,
                          folder=='saf' ~ st$rprtsaf,
                          folder=='pkp' ~ st$rprtpkpd,
                          TRUE ~ str_replace(st$rprteff,r'(\w+/?$)','') ) |>
    file.path(paste0(idkey_row$RTF.Output.number,".rtf"))
  
  # Create report layout
  if (str_detect(idkey,'^P[TFL]P')) {
    orientation <- 'portrait'
    margin <- c(2.01,3.81,3,1.98)
    footnote_pad <- 50
  } else {
    orientation <- 'landscape'
    margin <- c(3,0.98,3.81,2.01)
    footnote_pad <- 120
  }
  progfootnote <- str_replace(st$pgmfile,r'(/view/\w+_view/vob(/\w+){2})','') |>
    paste(format(Sys.time(),"%d%b%Y %H:%M")) |>
    str_pad(footnote_pad,side='right') |>
    paste0(st$referenc)
  shell <- create_report(outputfile, output_type = "RTF", paper_size='A4', units = 'cm',
                         font = "Arial", font_size = 9, orientation=orientation) |>
    set_margins(top = margin[1], bottom = margin[2], left=margin[3], right=margin[4]) |>
    titles(st$title00, align='left',bold=TRUE) %>%
    footnotes(progfootnote, valign = 'bottom',align = 'left')
  
  return(list(shell = shell, title = title, footnote = footnote))
}










#' Read a cell-based rtf file into a data.frame
#'
#' @param rtffile    rtf file name with directory(mandatory), e.g., rtffile=paste0(st$rprtsaf,"t1431_07.rtf")
#'
#' @param compress   remove all blanks(optional, default: "N")
#'        1) not compress any column: "N"
#'        2) compress all columns: "all"
#'        3) compress some column(s): column name(s) separated by comma, e.g., "col1, col2"
#'                                      if columns listed are not to compress, add - ahead, e.g., "- col1, col2"
#'
#' @param retain     retain not missing value in previous row to the following row(optional, default: "N")
#'        1) not retain any column: "N"
#'        2) retain some column(s): column names separated by comma, e.g., "col1, col2"
#'
#' @param blankrow   how to deal with rows with only col1 not missing(optional, default: "keep")
#'        1) keep it as it is: "keep"
#'        2) delete such row(s): "remove"
#'        3) put not missing col1 to col00, retain col00 and delete blank row(s): "addcol00"
#'        4) combine folded lines in col1: "cellwrap"
#'
#' @param bign       save bigN in a separate dataframe(optional, default: "N")
#'        1) no bigN: "N"
#'        2) for by subgroup table: "subgroup"
#'        3) for not by subgroup table: "Y"
#'        if bigN needed, a list with 2 dataframes will be returned, with table content saved in 'dev' and bign saved in 'bign'
#'
#' @return A data frame read from given rtf file
#'
#' @examples
#' dev <- read_rtf2(paste0(st$rprtsaf,"t1431_07.rtf"))
#' dev <- read_rtf2(paste0(st$rprtsaf,"t1431_07.rtf"), compress = "-col1", retain = "col1", blankrow = "addcol00")
#' @export
read_rtf2 <- function(rtffile, compress="N", retain="N", blankrow="keep", bign="N"){
  # developed by Zongle
  tran <- function(intext){
    intext <- gsub("[[:space:]]", "", intext)
    
    if (regexpr("col", intext)[1] != -1 & regexpr("c\\(.*\\)", intext)[1] == -1){
      if (substr(intext, 1, 1) == '-'){
        subtext <- substr(intext, 2, nchar(intext))
      } else{
        subtext <- intext
      }
      
      subtext1 = subtext %>%
        gsub("(col[0-9]{1,2})", "'\\1'", .) %>%
        gsub("(.*)", "c(\\1)", .)
      
      if (substr(intext, 1, 1) == '-'){
        outtext <- paste0('-', subtext1)
      } else{
        outtext <- subtext1
      }
    }
    else outtext <- intext
    return(outtext)
  }
  
  compress = compress %>% tolower() %>% tran()
  retain = retain %>% tolower() %>% tran()
  blankrow = tolower(blankrow)
  
  sz  <- file.info(rtffile)$size
  raw <- readBin(rtffile, what = "raw", n = sz)
  raw[raw == as.raw(0xA0)] <- as.raw(0x20)
  txt  <- iconv(rawToChar(raw), from = "latin1", to = "UTF-8", sub = "")
  lines <- strsplit(txt, "\n", fixed = TRUE)[[1]]
  rtf0 <- data.table(V1 = lines)
  
  #convert unicode back to ^
  rtf0[, V1 := str_replace_all(V1, r"(\{\\uc0\\u94\s*\})", "^")]
  rtf0[, V1 := str_replace_all(V1, r"(\{\\super ([^}]*)\})", "^\\1")]
  
  # group page
  rtf0[regexpr(r"(\\pagebb|\\sect)", V1) != -1, page := .I]
  setnafill(rtf0, "locf", cols = 'page')
  rtf1 <- rtf0[!is.na(page),]
  # rtf1[, page_N := 1:.N, by = page]
  
  # group block, split by {\\par}
  rtf1[V1 == '{\\par}', block := 1:.N, by = page]
  rtf1[, block := zoo::na.locf(block, fromLast = TRUE, na.rm = FALSE), by = page]
  
  # group row and remove things except row
  rtf1[, row_begin := regexpr(r"(\\trowd)", V1)]
  rtf1[, row_end := as.double(regexpr(r"(\\row)", V1))]
  rtf1[regexpr(r"(\\trowd)", V1) != -1, row_begin := 1:.N, by = page]
  rtf1[regexpr(r"(\\row)", V1) != -1, row_end := (1:.N) + 0.1, by = page]
  
  rtf1[row_begin == -1, row_begin := NA]
  rtf1[row_end == -1, row_end := NA]
  
  rtf1[, row_begin := zoo::na.locf(row_begin, na.rm = FALSE), by = .(page)]
  rtf1[, row_end := zoo::na.locf(row_end, fromLast = TRUE, na.rm = FALSE), by = .(page)]
  
  # keep blocks before row(may contain subtitle), drop blocks after row
  # remove block separator {\\par}
  rtf1_ <- rtf1[!is.na(row_end) & V1 != '{\\par}',]
  # fake row 0: title, subtitle, etc. (things before header)
  rtf1_[is.na(row_begin), row_begin := 0]
  
  rtf1_[, row_end := NULL]
  setnames(rtf1_, "row_begin", "row0")
  
  # last block in row 0
  rtf1_[row0 == 0, last_block := max(block), by = .(page, row0)]
  rtf1_[row0 == 0, left := regexpr(r"(\\ql)", V1) != -1, by = .(page, row0)]
  rtf1_[row0 == 0, head_grp := rleid(left), by = .(page, row0)]
  
  # if there are subtitle(s), last block(s) before first solid line which is left aligned
  rtf1_[block == last_block & regexpr(r"(\\ql)", V1) != -1,  role := 'subtitle']
  rtf1_[row0 == 0, role := zoo::na.locf(role, fromLast = TRUE, na.rm = FALSE), by = .(page, head_grp)]
  
  subtitle0 <- rtf1_[role == 'subtitle', .(V1, page)]
  subtitle0[, subval := str_extract(V1, "(?<=\\{).*(?=\\})")]
  subtitle0_ <- subtitle0[!is.na(subval) & subval != "", lvl_head := .N, , by = page]
  
  # combine multiple subtitles together
  if (nrow(subtitle0_) > 0 && max(subtitle0_$lvl_head) > 1){
    subtitle <- subtitle0_[, .(subval = paste(subval, collapse = "@")), by = page]
  } else {
    subtitle <- subtitle0
  }
  
  
  # move subtitle from row to column
  rtf2 <- merge(rtf1_[row0 > 0, .(V1, page, row0)], subtitle[, .(page, subval)], by = 'page', all.x = TRUE)
  # row number in each page
  max_row <- max(rtf2$row0)
  # make var row unique among pages
  rtf2[, row := (page - 1) * max_row + row0]
  
  
  # number of cells in each row
  rtf2[, cell_count := str_count(V1, "\\\\cellx")]
  rtf2[, sum_cell := sum(cell_count), by = row]
  
  # number of cells with solid line in each row
  rtf2[, top_count := str_count(V1, "\\\\clbrdrt")]
  rtf2[, sum_top_line := sum(top_count), by = row]
  
  rtf2[, bottom_count := str_count(V1, "\\\\clbrdrb")]
  rtf2[, sum_bottom_line := sum(bottom_count), by = row]  
  
  # entire line on top or bottom
  unique <- distinct(rtf2, page, row, sum_cell, sum_top_line, sum_bottom_line)
  solid_bottom <- unique[sum_cell == sum_bottom_line,]
  solid_top <- unique[sum_cell == sum_top_line,]
  
  # unify to bottom
  solid_top[, row := row - 1]
  solid_unify <- rbind(solid_top, solid_bottom)
  
  # rows with underline
  underline <- distinct(solid_unify, row)
  underline$underline = 'Y'
  
  rtf2[, c('cell_count', 'sum_cell', 'top_count', 'sum_top_line', 'bottom_count', 'sum_bottom_line') := NULL]
  
  unique1 <- merge(unique[, .(page, row)], underline, by = 'row', all.x = TRUE)
  
  # group section, split by underline
  unique1[!is.na(underline) & underline == 'Y', section0 := 1:.N , by = page]
  unique1[, section := section0]
  unique1[, section0 := NULL]
  unique1[, section := zoo::na.locf(section, fromLast = TRUE, na.rm = FALSE), by = page]
  
  unique1[section == 1, role := 'col_name']
  unique1[section == 2, role := 'body']
  
  # merge role in
  rtf3 <- rtf2[unique1[, .(row, role, section)], on = 'row'][
    V1 != '{\\row}' & regexpr(r"(\\trowd)", V1) == -1] # remove row control word
  
  # position containing `\cellx`
  rtf3[regexpr("\\\\cellx\\d+", V1) != -1, role1 := 'position']
  rtf3[role1 == 'position', position := 1:.N , by = .(row, role1)]
  
  rtf3[is.na(role1), role1 := 'content']
  rtf3[regexpr("\\\\cell\\}", V1) != -1, cell := 1:.N , by = .(row, role1)]
  rtf3[, cell := zoo::na.locf(cell, fromLast = TRUE, na.rm = FALSE), by = .(row, role1)]
  
  # remove all "control word" 
  rtf3[, val := trimws(str_replace_all(V1, "\\{?\\\\[a-zA-Z]+-?\\d*\\{?\\}?", ""))]
  
  
  # things except position in row: content
  content <- rtf3[role1 == 'content', ]
  content[, c('V1', 'role1', 'position') := NULL]
  
  # separate because need delimiter for col_name, update as no
  col_name <- content[role == 'col_name',]
  body <- content[role == 'body',]
  
  if (nrow(body) == 0) return(tibble())
  
  # combine val in same cell
  com_col_name <- col_name[, .(value = paste0(val, collapse = "")), by = .(page, subval, row0, row, cell)][
    ,.(page, subval, row, cell, value)]
  
  # assume same column&header structure in every page: keep only page 1
  unique_sub <- com_col_name[, .(page = min(page)), by = subval]
  uni_col_name <- com_col_name[unique_sub[, .(page)], on = 'page']
  
  com_body <- body[, .(value = paste0(val, collapse = "")), by = .(page, subval, row0, row, cell)]
  
  
  head_pos <- rtf3[role == 'col_name' & role1 == 'position', .(page, row, position, V1)]
  head_pos[, pos := as.numeric(sub(".*\\\\cellx([0-9]+).*", "\\1", V1))]
  head_pos[, V1 := NULL]
  
  # merge position and content of colname together
  col_name1 <- head_pos[uni_col_name, on = .(page = page, row = row, position = cell)]
  
  # how many column in each row  
  header_struct <- col_name1[, .(col_num = max(position)), by = .(page, row)]
  
  # column name in how many row
  row_num_col_name <- header_struct[, .(row_num = uniqueN(row)),by=page][
    1, row_num]
  
  # if column number same across rows, combine
  if(row_num_col_name > 1){
    if(uniqueN(header_struct$col_num) == 1){
      # split each column name row in separate data.table
      for (i in 1:row_num_col_name) {
        temp <- uni_col_name[row == i, .(cell, value)]
        setnames(temp, "value", paste("value", i, sep = "_"))
        
        dataframe_name <- paste("col_name", i, sep = "_")
        assign(dataframe_name, temp)
      }
      
      # data.tables with name starts with col_name_
      object_names <- ls(pattern = "^col_name_")
      
      # merge column names in different rows together into merged_dt
      merged_dt <- get(object_names[1])
      
      for (i in 2:length(object_names)) {
        current_dt <- get(object_names[i])
        merged_dt <- merge(merged_dt, current_dt, by = "cell", all = TRUE, suffixes = c("", paste0("_", i)))
      }
      
      # combine columns start with value_ into value, overwrite data.table col_name1
      col_name1 <- unite(merged_dt, value, starts_with('value_'), sep = "", remove = FALSE, na.rm = TRUE) %>% 
        data.table()
    } 
  }
  
  
  if (bign != 'N'){
    keep0 <- 'value'
    if (bign == 'subgroup') {
      keep <- c('subval', 'value')
    } else {keep0 <- 'value'}
    bigN0 <- col_name1[regexpr(r"(.*N([[:space:]])*=([[:space:]])*[0-9]+)", value) != -1, ..keep0]
    bigN0[, trt := sub("(.*)N\\s*=\\s*[0-9]+.*", "\\1", value)]
    bigN0[, bign := as.numeric(sub(".*N\\s*=\\s*([0-9]+).*", "\\1", value))]
    
    keep <- c('trt', 'bign')
    if (bign == 'subgroup') {
      keep <- c('subval', keep)
      bigN <- bigN0[, ..keep] %>% setnames(., old = "subval", new = "col0") %>% unique()
    } else {bigN <- bigN0[, ..keep] %>% unique()}
  }
  
  
  body[, c('page', 'row0', 'role', 'section') := NULL]
  
  #save column id
  body[, id := paste0('col', cell)]
  
  #column position in numerical ascending order, to retain transposed data.table
  col_pos = paste0("c('", paste(unique(body[,.(id)])[[1]], collapse ="','"), "')")
  
  #remove non-breaking space, i.e. byte(160)
  body[, val := str_remove_all(val, "(\\xA0)")]
  
  compress=gsub("[[:space:]]", "", compress)
  if (compress != "n") {
    if (compress == "all") {
      body[, val := gsub("[[:space:]]", "", val)]
      body[, val := str_remove_all(val, "(\\xA0)")]
    } else if (substr(compress,1,1) == "-") {
      rtf_scope1 = substr(compress, 2, nchar(compress))
      body[!(id %in% eval(parse(text=rtf_scope1))), val := gsub("[[:space:]]", "", val)]
      body[!(id %in% eval(parse(text=rtf_scope1))), val := str_remove_all(val, "(\\xA0)")]
    } else {
      body[id %in% eval(parse(text=compress)), val := gsub("[[:space:]]", "", val)]
      body[id %in% eval(parse(text=compress)), val := str_remove_all(val, "(\\xA0)")]
    }
  }
  
  #change "" to NA for columns to retain
  if (retain != "n") {
    body[id %in% eval(parse(text=retain)), val := na_if(val, "")]
  }
  
  #transpose
  rtf4 <- dcast(body, row + subval ~ id, value.var="val")
  setcolorder(rtf4, eval(parse(text=col_pos)))
  
  #remove rows with all columns missing
  rtf4 <- unite(rtf4, concat0, starts_with('col'), sep = "", remove = FALSE, na.rm = TRUE) %>% data.table()
  rtf4[, concat0 := gsub("[[:space:]]", "", concat0)]
  rtf4 <- rtf4[concat0 != ""]
  
  if (blankrow != "keep") {
    rtf_col <- grep("col", names(rtf4), value=T)
    col_exp1 <- grep("^col1$", rtf_col, invert=T, value=T)
    rtf4 <- unite(rtf4, concat, all_of(col_exp1), sep = "", remove = FALSE, na.rm = TRUE) %>% data.table()
    rtf4[, concat := gsub("[[:space:]]", "", concat)]
    if (blankrow == "remove") {
      rtf4 <- rtf4[concat != ""]
    } else if (blankrow == "cellwrap"){
      # cat col1 with other cols missing to the above row, turn multiple blanks leading this col1 to one
      rtf4$wrap <- 0
      rtf4$id <- 0
      rtf4[concat != "", wrap := .(.I)]
      rtf4[concat == "", col1 := gsub("^\\s{2,}", " ", col1)]
      rtf4[wrap == 0, wrap := NA]
      rtf4 <- tidyr::fill(rtf4, wrap, .direction = "down")
      rtf4[, id := seq_len(.N), by = wrap]
      
      fold <- dcast(rtf4[,.(wrap, id, col1)],
                    wrap ~ id,
                    value.var = c("col1"))
      
      col_exp2 <- grep("^wrap$", colnames(fold), invert=T, value=T)
      fold1 <- unite(fold, col1, all_of(col_exp2), sep = "", remove = FALSE, na.rm = TRUE) %>% data.table()
      fold2 <- fold1[,.(wrap, col1)]
      rtf4_ <- rtf4[concat != ""]
      rtf4_[, col1 := NULL]
      rtf4 <- merge(fold2, rtf4_, by = 'wrap')
    } else if (blankrow == "addcol00"){
      rtf4[concat == "" & col1 != "", col00 := col1]
      rtf4 <- tidyr::fill(rtf4, col00, .direction = "down")
      rtf4 <- rtf4[concat != ""]
      setcolorder(rtf4, "col00")
    } 
  }
  
  #put subtitle into col0
  if (all(is.na(rtf4$subval)) == FALSE) {
    rtf4[, col0 := subval]
    setcolorder(rtf4, "col0")
  }
  
  if (retain != "n") {
    rtf4 <- rtf4 %>% mutate_at(eval(parse(text=retain)), ~na_if(., "")) %>%
      tidyr::fill(., eval(parse(text=retain)), .direction = "down")
  }
  
  rtf_col=grep("^col", names(rtf4), value=T)
  #remove leading and trailing blanks
  out <- rtf4[, ..rtf_col] %>%
    map_df(trimws, "both") %>%
    mutate_if(is.character, ~replace_na(., ""))
  # print(out, n = Inf, width = Inf)
  if (bign == 'N'){
    return(out)
  } else {
    all <- list("dev"=out, "bign"=bigN)
    return(all)
  }
}








#' Read a reporter package generated rtf file into a data.frame
#'
#' @param rtffile    rtf file name with directory(mandatory), e.g., rtffile=paste0(st$rprtsaf,"t1431_07.rtf")
#'
#' @param compress   remove all blanks(optional, default: "N")
#'                   1) not compress any column: "N"
#'                   2) compress all columns: "all"
#'                   3) compress some column(s): column name(s) separated by comma, e.g., "col1, col2"
#'                                               if columns listed are not to compress, add - ahead, e.g., "- col1, col2"
#'
#' @param retain     retain not missing value in previous row to the following row(optional, default: "N")
#'                   1) not retain any column: "N"
#'                   2) retain some column(s): column names separated by comma, e.g., "col1, col2"
#'
#' @param blankrow   how to deal with rows with only col1 not missing(optional, default: "keep")
#'                   1) keep it as it is: "keep"
#'                   2) delete such row(s): "remove"
#'                   3) put not missing col1 to col00, retain col00 and delete blank row(s): "addcol00"
#'
#' @param header     display column headers as label or not(optional, default: "Y")
#'                   1) display column headers: "Y"
#'                   2) not display column headers: "N"
#'                   
#' @details
#' default settings: 1) columns are be stripped
#'                   2) subtitles are put into col0
#'                   3) blank rows are removed
#'                   4) column names are put into labels; column names in multiple rows are combined together, separated by @
#'
#' @examples
#' dev <- read_rtf3(paste0(st$rprtsaf,"t1431_07.rtf"))
#' dev <- read_rtf3(paste0(st$rprtsaf,"t1431_07.rtf"), compress = "-col1", retain = "col1", blankrow = "addcol00")
#' @export
read_rtf3 <- function(rtffile, compress="N", retain="N", blankrow="keep", header="Y"){
  # developed by Zongle
  tran <- function(intext){
    intext <- gsub("[[:space:]]", "", intext)
    
    if (regexpr("col", intext)[1] != -1 & regexpr("c\\(.*\\)", intext)[1] == -1){
      if (substr(intext, 1, 1) == '-'){
        subtext <- substr(intext, 2, nchar(intext))
      } else{
        subtext <- intext
      }
      
      subtext1 = subtext %>%
        gsub("(col[0-9]{1,2})", "'\\1'", .) %>%
        gsub("(.*)", "c(\\1)", .)
      
      if (substr(intext, 1, 1) == '-'){
        outtext <- paste0('-', subtext1)
      } else{
        outtext <- subtext1
      }
    }
    else outtext <- intext
    return(outtext)
  }
  
  compress = compress %>% tolower() %>% tran()
  retain = retain %>% tolower() %>% tran()
  blankrow = tolower(blankrow)
  
  rtf0 <- data.table(read.delim(rtffile, header = FALSE, col.names="V1", blank.lines.skip = FALSE))
  
  # remove rows with header and footer
  rtf1 <- rtf0[grepl("\\{\\\\(header|footer)", V1, perl = TRUE) == FALSE,]
  
  # group page
  rtf1[regexpr(r"(\\pagebb|\\sect)", V1) != -1, page := .I]
  setnafill(rtf1, "locf", cols = 'page')
  rtf1[is.na(page), page := 0]
  
  # group block, split by blank line
  rtf1[V1 == '', block := .I]
  setnafill(rtf1, "nocb", cols = 'block')
  
  # group row and remove things except row
  rtf1[, row_begin := regexpr(r"(\\trowd)", V1)]
  rtf1[, row_end := as.double(regexpr(r"(\\row)", V1))]
  rtf1[regexpr(r"(\\trowd)", V1) != -1, row_begin := .I]
  rtf1[regexpr(r"(\\row)", V1) != -1, row_end := .I + 0.1]
  
  setnafill(rtf1, "locf", cols = 'row_begin')
  setnafill(rtf1, "nocb", cols = 'row_end')
  rtf2 <- rtf1[as.character(row_begin) == word(row_end, 1, sep = fixed('.')) & V1 != '' & !(row_begin < 0 & row_end < 0), ]
  rtf2[, row_end := NULL]
  setnames(rtf2, "row_begin", "row")
  
  
  # solid line in each page
  solid_line <- rtf2[regexpr(r"(\\brdrs)", V1) != -1, .(V1, row)]
  
  # number of cells in each row
  solid_line[, cell_count := str_count(V1, "\\\\cellx")]
  # number of cells with solid line in each row
  solid_line[, top_count := str_count(V1, "\\\\clbrdrt")]
  solid_line[, bottom_count := str_count(V1, "\\\\clbrdrb")]
  
  
  # entire line on top or bottom
  solid_bottom <- solid_line[cell_count == bottom_count,]
  solid_top <- solid_line[cell_count == top_count,]
  
  # unify to bottom
  solid_top[, row := row - 1]
  solid_unify <- rbind(solid_top, solid_bottom)
  
  underline <- unique(solid_unify[,.(row)], by = 'row')
  underline[, underline := 'Y']
  rtf3 <- merge(rtf2, underline, by = "row", all.x = TRUE)
  
  # group section, split by underline
  rtf3[underline == 'Y', section := 1:.N , by = page]
  rtf3[, section := zoo::na.locf(section, fromLast = TRUE, na.rm = FALSE), by = page]
  
  # last block in section 1
  rtf3[section == 1, last_block := max(block), by = .(page, section)]
  
  # if there is subtitle, last block before first solid line which is left aligned
  rtf3[block == last_block & regexpr(r"(\\ql)", V1) != -1,  role := 'subtitle']
  rtf3[section == 2, role := 'col_name']
  rtf3[section == 3, role := 'body']
  
  # each \cell 
  rtf3[, cell_match := str_match_all(V1, "\\\\cell(?![a-zA-Z0-9])")]
  
  # keep things of use
  rtf4 <- rtf3[!is.na(role), .(V1, page, row, section, role)]
  
  # if more than one cell in same literal row, split one row for each cell
  if(max(nchar(rtf3$cell_match)) > 5){
    
    rtf4[, n := 1:.N]
    
    # to store the splitted 
    cell_position <- data.table(n = integer(), Cellx = character())
    cell_content <- data.table(n = integer(), CellPart = character())
    
    # Extract substrings containing `\cellx` and retain line numbers, split the remaining text by `\cell`
    for (i in 1:nrow(rtf4)) {
      N <- i
      
      # Extract and remove `\cellx\d+` from V1
      matches_cellx <- str_extract_all(rtf4$V1[i], "\\\\cellx\\d+")[[1]]
      remaining_text <- str_remove_all(rtf4$V1[i], "\\\\cellx\\d+")
      
      if (length(matches_cellx) > 0) {
        cell_position <- rbind(cell_position, data.table(n = N, Cellx = matches_cellx))
      }
      
      # split the remaining text by `\cell`
      parts <- unlist(strsplit(remaining_text, "\\\\cell"))
      # parts <- parts[parts != ""]  # remove blank string
      if (length(parts) > 1) {
        parts <- parts[-length(parts)]  # remove the last part
      }
      if (length(parts) > 0) {
        cell_content <- rbind(cell_content, data.table(n = N, CellPart = parts))
      }
    }
    
    # remove all "control word" 
    cell_content[,content := trimws(str_replace_all(CellPart, "\\{?\\\\[a-zA-Z]+-?\\d*", ""))]
    cell_content[,n_in_n := 1:.N, by = n]
    cell_position[,n_in_n := 1:.N, by = n]
    
    if(header == 'Y'){
      expanded <- merge(cell_position, cell_content, by = c("n", "n_in_n"), all = TRUE)
      
      col_name <- merge(rtf4[role == 'col_name' & page == 1,], expanded, by = "n", all.x = TRUE)
      # how many column header(name) row in each page
      row_col_name <- col_name[, .(unique_row_count = uniqueN(row)), by = page]
      
      # row number of column names
      row_num_col_name <- max(row_col_name$unique_row_count, na.rm = TRUE)
      
      # if column name in more than one row, need further combine
      if(row_num_col_name > 1) {
        col_name[, pos := as.numeric(sub(".*\\\\cellx([0-9]+).*", "\\1", Cellx))]
        # the nst row of colname in page
        col_name[, n_row := match(row, unique(row)), by = page]
        
        # split each column name row in separate data.table
        for (i in 1:row_num_col_name) {
          temp <- col_name[n_row == i, .(content, pos)]
          setnames(temp, "content", paste("content", i, sep = "_"))
          
          dataframe_name <- paste("col_name", i, sep = "_")
          assign(dataframe_name, temp)
        }
        
        # data.tables with name starts with col_name_
        object_names <- ls(pattern = "^col_name_")
        
        # merge column names in different rows together into merged_dt
        merged_dt <- get(object_names[1])
        
        for (i in 2:length(object_names)) {
          current_dt <- get(object_names[i])
          merged_dt <- merge(merged_dt, current_dt, by = "pos", all = TRUE, suffixes = c("", paste0("_", i)))
        }
        
        # column names start with content_
        content_cols <- grep("^content_", names(merged_dt), value = TRUE)
        
        # spanning header: nocb for columns(with name start with content_)
        merged_dt[, (content_cols) := lapply(.SD, function(x) zoo::na.locf(x, fromLast = TRUE, na.rm = FALSE)), .SDcols = content_cols]
        
        # combine columns start with content_ into col_name
        merged_dt[, col_name := apply(.SD, 1, function(row) {
          paste(row[row != ""], collapse = "@")
        }), .SDcols = content_cols]
        
        col_names <- merged_dt[, col_name]
        
      } else {
        col_names <- col_name[, content]
      }
    }
    
    
    rtf5 <- merge(rtf4[role != 'col_name',], cell_content, by = "n", all.x = TRUE)
    rtf_body <- rtf5[role == 'body', .(page, row, n_in_n, content)]
    
    #remove non-breaking space, i.e. byte(160)
    rtf_body[, id := paste0('col', n_in_n)]
    rtf_body[, val := str_remove_all(content, "(\\xA0)")]
    
    rtf_body[, c('n_in_n', 'content') := NULL]
    
    compress=gsub("[[:space:]]", "", compress)
    if (compress != "n") {
      if (compress == "all") {
        rtf_body[, val := gsub("[[:space:]]", "", val)]
        rtf_body[, val := str_remove_all(val, "(\\xA0)")]
      } else if (substr(compress,1,1) == "-") {
        rtf_scope1 = substr(compress, 2, nchar(compress))
        rtf_body[!(id %in% eval(parse(text=rtf_scope1))), val := gsub("[[:space:]]", "", val)]
        rtf_body[!(id %in% eval(parse(text=rtf_scope1))), val := str_remove_all(val, "(\\xA0)")]
      } else {
        rtf_body[id %in% eval(parse(text=compress)), val := gsub("[[:space:]]", "", val)]
        rtf_body[id %in% eval(parse(text=compress)), val := str_remove_all(val, "(\\xA0)")]
      }
    }
    
    #change "" to NA for columns to retain
    if (retain != "n") {
      rtf_body[id %in% eval(parse(text=retain)), val := na_if(val, "")]
    }
    
    #column position in numerical ascending order, to retain transposed data.table
    col_pos = paste0("c('", paste(unique(rtf_body[,.(id)])[[1]], collapse ="','"), "')")
    
    #transpose
    body <- dcast(rtf_body, page + row ~ id, value.var="val")
    setcolorder(body, eval(parse(text=col_pos)))
    
    #remove rows with all columns missing
    body <- unite(body, concat0, starts_with('col'), sep = "", remove = FALSE, na.rm = TRUE) %>% data.table()
    body[, concat0 := gsub("[[:space:]]", "", concat0)]
    body <- body[concat0 != ""]
    body[, concat0 := NULL]
    
    if (blankrow != "keep") {
      rtf_col <- grep("col", names(body), value=T)
      col_exp1 <- grep("^col1$", rtf_col, invert=T, value=T)
      body <- unite(body, concat, all_of(col_exp1), sep = "", remove = FALSE, na.rm = TRUE) %>% data.table()
      body[, concat := gsub("[[:space:]]", "", concat)]
      if (blankrow == "remove") {
        body <- body[concat != ""]
      } else if (blankrow == "addcol00"){
        body[concat == "" & col1 != "", col00 := col1]
        body <- tidyr::fill(body, col00, .direction = "down")
        body <- body[concat != ""]
        setcolorder(body, "col00")
        if(header == 'Y') {col_names <- c('category', col_names)}
      } 
    }
    
    # subtitle
    if(rtf3[role == 'subtitle', .N] > 0){
      rtf_subtitle <- rtf5[role == 'subtitle', .(page, row, content)]
      # combine subtitle in same page across rows
      subtitle <- rtf_subtitle[, .(col0 = paste(content, collapse = "")), by = page]
      body <- subtitle[body, on = 'page']
      
      if(header == 'Y') {col_names <- c('subtitle', col_names)}
    }
    
    if (retain != "n") {
      body <- body %>% mutate_at(eval(parse(text=retain)), ~na_if(., "")) %>%
        tidyr::fill(., eval(parse(text=retain)), .direction = "down")
    }
    
    rtf_col <- grep("^col", names(body), value=T)
    
    #remove leading and trailing blanks
    out <- body[, ..rtf_col] %>%
      map_df(trimws, "both") %>%
      mutate_if(is.character, ~replace_na(., ""))
    
    if(header == 'Y') {
      # apply label
      for (i in seq_along(col_names)) {
        Hmisc::label(out[[i]]) <- col_names[i]
      }
    }
    
    return(out)
  }
}


#' Create absolute paths relative to study activity.
#'
#' It contains paths from /vob/util/GPS_Macro_library/Utility_Macro/reflib.sas7bdat and some other elements.
#' `data_s` is assigned to sourcedata in RA folder if existing, otherwise it's assigned to sourcedata out of RA folder.
#' `pgmfile` is the current program path/name.
#' `ctc_ncds`, `scrgr`, `scrgmd`, `scrgmc` are some paths to global metadata.
#'
#' @param dir a string indicating the path of R program executing
#' @return A list storing study relative paths and other global paths
#' @examples
#' set_paths(rstudioapi::getSourceEditorContext()$path)
#' @export
set_paths <- function(dir=getwd()) {
  # developed by Carlos
  st <- list(wd=ifelse(interactive(),dirname(dir),dir), userid=Sys.getenv("USER"))
  cat(paste("Executing in", st$wd, '\n'))
  #assign userid, project, protocol, report
  wd_pattern <- regex(r'(/vob/(\w+)/(\w+)/(\w+))')
  if (str_detect(st$wd,wd_pattern)) {
    st$project <- str_match(st$wd,wd_pattern)[2]
    st$protocol <- str_match(st$wd,wd_pattern)[3]
    st$report <- str_match(st$wd,wd_pattern)[4]
    st$genpgm <- sprintf("/view/%s_view/vob/%s/%s/%s/",st$userid,st$project,st$protocol,st$report)
  } else {
    warning(paste0("Input path '",dir,"' is not under report activity level like CABC123D/CABC123D4567/csr_x/..."))
  }

  # Importing reflib dataset
  reflib2 <- sprintf('/view/%s_view/vob/util/GPS_Macro_library/Utility_Macro/reflib.sas7bdat',st$userid) %>% 
    read_sas() %>% filter((activ_na=='A' & GPS_Release == 'R3' & type == 'LIBNAME') | alias=='PUTIL')
  reflib2$val_path2 <- reflib2$val_path %>% str_replace_all("<proj>",st$project) %>%
    str_replace_all("<prot>",st$protocol) %>%
    str_replace_all("<rprt>",st$report) %>%
    str_replace(r"((?<=[^/])$)","/")
  reflib2$val_path3 <- paste0('/view/',st$userid,'_view',reflib2$val_path2)

  st <- c(st,split(reflib2$val_path3,tolower(reflib2$alias)))
  st$data_s <- ifelse(dir.exists(paste0(st$genpgm,'sourcedata/')),paste0(st$genpgm,'sourcedata/'),st$data_s)

  #get program path, name and version
  if (interactive()) {
    pgmfile <- rstudioapi::getSourceEditorContext()$path
  } else {
    pgmfile <- file.path(st$wd,str_extract(str_subset(commandArgs(),'\\w+\\.R')[1],'\\w+\\.R'))
  }
  st$pgmfile <- system(paste0("cleartool descr -s ",pgmfile),intern=T)

  #assign global paths
  st$ctc_ncds <- paste0("/view/", st$userid, "_view/vob/util/Oncology/CTC/ncds/data/")
  st$scrgr <- paste0("/view/", st$userid, "_view/vob/SCRCENTRAL/reference/referencedata/")
  st$scrgmd <- paste0("/view/", st$userid, "_view/vob/SCRCENTRAL/reference/metadata/")
  st$scrgmc <- paste0("/view/", st$userid, "_view/vob/SCRCENTRAL/reference/codelists/")

  return(st)
}









#' Read data from library in list st. Support multiple file formats.
#'
#' By default, variables are renamed to low case. And attributes are removed.
#' If the filename extension is not given, rds, csv, txt, sas7bdat, xpt is searched in sequence.
#' The first one found is read in.
#'
#' @param lib.data.ext A data file name with library and extension
#' @param n_max        Maximum number of lines to read. Not applicable for rds file.
#' @param simplify     If TRUE, the default, rename variables to low case and remove attributes.
#'                     If FALSE keep the original variable names and attributes.
#' @return A data frame read from lib.data.ext
#' @examples
#' read_df(analysis.adsl) #the first one of adsl.rds, adsl.csv, adsl.txt, adsl.sas7bdat, adsl.xpt found from st$analysis is read
#' read_df(analysis.adsl, n_max=100) #read the first 100 rows
#' read_df(analysis.adsl, simplify = FALSE) #keep attributes for QC compare
#' read_df(analysis.adsl.sas7bdat) #read adsl.sas7bdat from st$analysis
#' @export
read_df <- function(lib.data.ext, n_max = Inf, simplify = TRUE) {
  # developed by Carlos
  lib_data <- deparse(substitute(lib.data.ext)) %>% str_replace_all('\\s+','')
  #check the format of input parameter
  if (!str_detect(lib_data,r'(^(\w+)\.(\w+)(\.\w+)?$)'))
    stop("Parameter lib_data must be like library.data or library.data.ext")
  lib_data2 <- str_split_fixed(lib_data,'\\.',n=3)
  ext_low <- str_to_lower(lib_data2[3])
  exts <- c('RDS','Rds','rds','csv','txt','sas7bdat','xpt')

  #check library name
  try(if(!lib_data2[1] %in% names(st))
    stop(paste0('Library name "', lib_data2[1], '" is not in list st.')))

  #check file existing
  if (!ext_low %in% c(exts,''))
    stop(sprintf("The last part of lib_data has value other than rds, sas7bdat, csv, txt, xpt, <blank>. lib_data=%s",lib_data))
  else if (ext_low %in% exts) {
    filepath3 <- paste0(st[lib_data2[1]], lib_data2[2],'.',lib_data2[3])
    ext_found <- str_to_lower(lib_data2[3])
    if (!file.exists(filepath3)) stop(sprintf("File does not exist: %s",filepath3))
  } else if (ext_low=='') {
    filepaths <- paste0(st[lib_data2[1]], lib_data2[2],'.',exts)
    file_exist_fl <- file.exists(filepaths)
    filepath3 <- filepaths[file_exist_fl][1]
    ext_found <- str_to_lower(exts[file_exist_fl][1])
  }

  # read in data frame file
  if (ext_found=='rds') {
    df1 <- readRDS(filepath3)
  } else if (ext_found=='sas7bdat') {
    df1 <- read_sas(filepath3,n_max=n_max)
  } else if (ext_found=='xpt') {
    df1 <- read_xpt(filepath3,n_max=n_max)
  } else if (ext_found %in% c('csv','txt')) {
    df1 <- read_csv(filepath3,n_max=n_max) %>% mutate(across(where(is.character),~ if_else(is.na(.),"",.)))
  }

  # simplify data frame
  if (is.na(simplify) | simplify!=FALSE) {
    names(df1) <- str_to_lower(names(df1))
    #remove variable attributes
    df1<-zap_formats(df1)
    df1<-zap_label(df1)
  }
  return(df1)
}







#' Merge pure SDTM with supp SDTM data
#'
#' The filename extension is searched by sequence from rds, csv, txt, sas7bdat, xpt. The first one found is read in.
#' Condition not cover yet: supp.idvar has different values
#'
#' @param domain   A pure SDTM domain name
#' @param supp     A supp SDTM domain name
#' @param lib      Library name in st list storing SDTM data
#' @param simplify If TRUE, the default, rename variables to low case and remove attributes.
#'                 If FALSE keep the original variable names and attributes.
#' @return A data frame merged pure SDTM and supp SDTM data
#' @examples
#' merge_supp(dm) #If derived.suppdm exists, merge derived.dm and derived.suppdm and return a data frame
#'                #If derived.suppdm does not exists, return dm
#' @export
merge_supp <- function(domain, supp, lib = derived, simplify = TRUE) {
  # developed by Carlos
  domain1 <- str_to_upper(deparse(substitute(domain)))
  lib1 <- str_to_lower(deparse(substitute(lib)))
  suppdomain1 <- str_to_lower(deparse(substitute(supp)))
  if (is.na(suppdomain1) | suppdomain1=="") suppdomain1 <- paste0('supp',str_to_lower(domain1))

  expr1 <- sprintf("pure1 <- read_df(%s.%s,simplify=FALSE)",lib1,str_to_lower(domain1))
  eval(parse(text=expr1))
  expr2 <- sprintf("supp1 <- read_df(%s.%s,simplify=FALSE)",lib1,suppdomain1)
  supp1 <- NULL
  tryCatch(eval(parse(text=expr2)),
           warning=function(w) { },
           error=function(e) { cat(paste0("No SUPP dataset to merge.\n")) }
           )

  if (!is.null(supp1)) {
    if (nrow(supp1)==0) cat(paste0("SUPP dataset has zero record.\n"))
  }

  if (is.null(supp1) || nrow(supp1)==0) {
    if (is.na(simplify) | simplify!=FALSE) {
      #rename variables to low case
      names(pure1) <- str_to_lower(names(pure1))

      #remove variable attributes
      pure1<-zap_formats(pure1)
      pure1<-zap_label(pure1)
    }
    return(pure1)
  }

  idkey1 <- names(supp1)[!names(supp1) %in% c("STUDYID","RDOMAIN","IDVAR","IDVARVAL","QNAM","QLABEL","QVAL","QORIG","QEVAL")]

  supp2 <- supp1 %>% select(-c('RDOMAIN','IDVAR',"QORIG","QEVAL",'QLABEL')) %>%
    pivot_wider(names_from="QNAM", values_from="QVAL")
  supp2 <- modify(supp2,function(x) `attributes<-`(x,NULL))

  #assign label to SUPP variables
  expr1 <- supp1 %>% select(QNAM,QLABEL) %>% distinct() %>%
    transmute(expr=paste0("attr(supp2$",QNAM,",'label') <- '",QLABEL,"'")) %>%
    unlist() %>%
    (function(x) parse(text=x))
  eval(expr1)

  #merge pure and supp
  idvar <- unique(supp1$IDVAR)
  if (length(idvar)>1) {
    stop(sprintf("SUPP%s has multiple values in IDVAR. It's not supported for now."),domain1)
    return(NULL)
  } else if (idvar=='') {
    final <- pure1 %>%
      left_join(supp2,by=c('STUDYID',idkey1)) %>%
      select(-IDVARVAL)
  } else {
    final <- pure1 %>% mutate(IDVARVAL=as.character(get(idvar))) %>%
      left_join(supp2,by=c('STUDYID',idkey1,'IDVARVAL')) %>%
      select(-IDVARVAL)
  }

  if (is.na(simplify) | simplify!=FALSE) {
    #rename variables to low case
    names(final) <- str_to_lower(names(final))

    #remove variable attributes
    final<-zap_formats(final)
    final<-zap_label(final)
  }
  return(final)
}








#' Round decimals like SAS
#'
#' @param x          a numeric vector
#' @param digits     integer indicating the number of decimal places to be used.
#' @param precision  a number to adjust precision when rounding is incorrect. It should be a number bigger than 1.
#' @return A rounded numeric value
#' @examples
#' x <- c(1/2, 1/3)
#' round2(x, 3)
#' round2(x, 3, precision=1.5)
#' @export
round2 <- function (x, digits = 0, precision = 1)  {
  posneg <- sign(x)
  z <- abs(x) * 10^digits
  z <- z + 0.5 + sqrt(.Machine$double.eps) * precision
  z <- trunc(z)
  z <- z/10^digits
  z * posneg
}








#' Convert numeric into character, keeping k decimals
#'
#' @param x A numeric vector to be converted
#' @param k Integer indicating the number of decimal places
#' @param precision A number to adjust precision when rounding is incorrect.
#'                  It should be a number bigger than 1.
#' @param negative_zero If TRUE, the default, negative sign may be kept for zero.
#'                      If FALSE, negative sign is removed for zero.
#'
#' @return A string formatted
#' @examples
#' x <- c(0.5, 1/3)
#' format2(x, 3)
#' format2(x, 3, precision=1.5)
#' format2(-0.01, 1, negative_zero=FALSE)
#' @export
format2 <- function(x, k, precision=1, negative_zero=TRUE) {
  # by developed Carlos
  if (is.na(negative_zero) | negative_zero!=FALSE) {
    sprintf(paste0("%.",as.character(k),"f"),round2(x,k,precision=precision))
  } else {
    str_replace(sprintf(paste0("%.",as.character(k),"f"),round2(x,k,precision=precision)),'^-(?=0\\.?0*$)','')
  }
}









#' Create variables -n/-s/-l in Numeric/Short/Long format according to global codelist
#'
#' @param dataframe a data frame
#' @param var the variable to be converted
#'
#' @return A data frame with some additional code variables
#' @examples
#' decode(dm, sex)
#' @export
decode <- function(dataframe, var){
 #developed by Songren
 #Load global codelist
  codelist <- read_df(rprtdsm.global_codelists)

  #Convert input into character
  in_var <- deparse(substitute(var))

  #Merge codelist and select target variable
  tmp <- codelist %>%
    filter(codelist == str_to_upper(in_var)) %>%
    select(codelist, code_c, code_n, decode_l, decode_s) %>%
    right_join(dataframe, by = c("decode_s" = in_var), keep = TRUE)

  #Rename decode variable
  tmp[, paste0(in_var, 'n')] <- tmp[, 'code_n']
  tmp[, paste0(in_var, 'l')] <- tmp[, 'decode_l']
  tmp[, paste0(in_var, 's')] <- tmp[, 'code_c']
  tmp[, in_var] <- tmp[, 'decode_s']

  tmp %>% select(-c(codelist, code_c, code_n, decode_l, decode_s)) %>% return()

}








#' Convert character -DTC variable into numeric -dtm/-dt/-tm variables expect partial dates
#'
#' @param dataframe   a data frame contain -DTC variable
#' @param in_dtc      the -DTC variable to be converted.
#' @param out_prefix  prefix of -DTM/-DT/-TM variables
#'
#' @return A data frame with some additional date time variables
#' @examples
#' dtc2dtm(ex, exstdtc, exst)
#' @export
dtc2dtm <- function(dataframe, in_dtc, out_prefix) {
  #developed by Songren
  out0 <- dataframe %>%
    filter(is.na({{in_dtc}}) == T)
  
  out1 <- dataframe %>%
    filter(str_length({{in_dtc}}) < 10)
  
  out2_1 <- dataframe %>%
    filter(str_length({{in_dtc}}) == 10) %>%
    mutate(.dtm = as.POSIXct(NA_character_, tz = 'UTC'),
           .dt  = as.Date({{in_dtc}}, tz = 'UTC'),
           .tm  = hms::as_hms(NA))
  
  out2_2 <- dataframe %>%
    filter(str_length({{in_dtc}}) > 10) %>%
    mutate(len = str_length({{in_dtc}}),
           has_sec = len > 16)
  
  out2_2sec <- out2_2 %>%
    filter(has_sec) %>%
    mutate(.dtm = as.POSIXct({{in_dtc}}, format = "%Y-%m-%dT%H:%M:%S", tz = 'UTC'),
           .dt  = as.Date(.dtm, tz = 'UTC'),
           .tm  = hms::hms(period_to_seconds(lubridate::hms(format(.dtm, "%H:%M:%S")))))
  
  out2_2min <- out2_2 %>%
    filter(len == 16) %>%
    mutate(.dtm = as.POSIXct({{in_dtc}}, format = "%Y-%m-%dT%H:%M", tz = 'UTC'),
           .dt  = as.Date(.dtm, tz = 'UTC'),
           .tm  = hms::hms(period_to_seconds(lubridate::hms(format(.dtm, "%H:%M:%S")))))
  
  out2_2miss <- out2_2 %>% 
    filter(10 < len & len < 16)%>%
    mutate(.dtm = as.POSIXct({{in_dtc}}, format = "%Y-%m-%dT%H", tz = 'UTC'),
           .dt  = as.Date(.dtm, tz = 'UTC'),
           .tm  = hms::hms(period_to_seconds(lubridate::hms(format(.dtm, "%H:%M:%S")))))
  
  out2_2all <- rbind(out2_2sec, out2_2min, out2_2miss) %>% select(-len, -has_sec)
  
  out2 <- rbind(out2_2all, out2_1)
  
  prefix<-deparse(substitute(out_prefix))
  out2[, paste0(prefix,'dtm')] <- out2[, '.dtm']
  out2[, paste0(prefix,'dt')]  <- out2[, '.dt']
  out2[, paste0(prefix,'tm')]  <- out2[, '.tm']
  
  #  nam <- paste0(prefix,'tm')
  #  attr(out2[[nam]],'units') <- NULL
  
  out2 %>%
    bind_rows(out0,out1) %>%
    select(-c(.dtm, .dt, .tm)) %>%
    return()
}









#' Print compare result returned by arsenal::comparedf
#'
#' Print compare result in Viewer tab in Rstudio interactive mode, or in html
#' file in bath run mode. The html file has the same name with program file.
#'
#' @param comdf A compare result returned by comparedf()
#' @param idkey The unique key of output compared. It's from PDT, column IDKEY.
#'
#' @return For RStudio, a compare result in Viewer
#'         For batch run, a html file with the same name with program file
#' @examples
#' comparedf(dev, qc) %>% print(idkey = 'ITP0001')
#' @export
print.comparedf <- function(comdf,idkey='') {
  # developed by Carlos
  com_sum0 <- summary(comdf,show.attrs=TRUE)
  com_sum1<-com_sum0$comparison.summary.table[c(4,5,6,9,10,11,13),] %>%
    pivot_wider(names_from='statistic',values_from='value')
  names(com_sum1) <- c('varx','vary','varne','obsx','obsy','obsne','ne')
  com_sum1$attrne <- nrow(com_sum0$attrs.table)
  com_sum2 <- {
    if (com_sum1$obsx+com_sum1$obsy>0) {
      'Observation Mismatch'
    } else if (com_sum1$ne>0) {
      'Value Mismatch'
    } else if (com_sum1$varx+com_sum1$vary>0) {
      'Variable Mismatch'
    } else if (com_sum1$attrne>0) {
      'Attribute Mismatch'
    } else {
      '_Match_'
    }
  }

  com_sum3 <- data.frame(idkey=idkey,
                         datetime=as.character(lubridate::now()),
                         sum=com_sum2,
                         stringsAsFactors=FALSE) %>%
              cbind(com_sum1)
  if ("print_comparedf" %in% names(st)) {
    st$print_comparedf <<- rbind(st$print_comparedf,com_sum3)
  } else {
    st$print_comparedf <<- com_sum3
  }

  html_com_sum <- str_c(str_c('<td style="text-align:left;">',com_sum3[1,1:3],'<\\/td>',collapse=' '),
                        str_c('<td style="text-align:right;">',com_sum3[1,-3:-1],'<\\/td>',collapse=' '),sep=' ')

  html_head <- '<style>table,table tr th, table tr td {border:1px solid #000000;}
                       table {border-collapse: collapse;} </style>\n'

  html_head2 <- '<table><h2>Summary of comparison</h2><thead><tr>
   <th style="text-align:left;">IDKEY</th>
   <th style="text-align:left;">Comparing<br>datetime</th>
   <th style="text-align:left;">Mismatch Type</th>
   <th style="text-align:right;">Number of<br>variables<br>in x but not y</th>
   <th style="text-align:right;">Number of<br>variables<br>in y but not x</th>
   <th style="text-align:right;">Number of<br>variables<br>compared<br>with some<br>values unequal</th>
   <th style="text-align:right;">Number of<br>observations<br>in x but not y</th>
   <th style="text-align:right;">Number of<br>observations<br>in y but not x</th>
   <th style="text-align:right;">Number of<br>observations<br>with some compared<br>variables unequal</th>
   <th style="text-align:right;">Number of<br>values unequal</th>
   <th style="text-align:right;">Number of<br>non-identical<br>attributes</th>
  </tr></thead><tbody>
  <!--generated by print.comparedf-->'

  if (!interactive()) {
    out<-str_replace(st$pgmfile,r'(\.R.*$)','.html')
    if (nrow(st$print_comparedf)==1) {
      c(html_head,html_head2) %>% writeLines(out)
      html_end <- '<\\/tbody><\\/table>'
    } else {
      html_end <- ''
    }

    sink(out, append=TRUE)
    cat(paste0('<hr/><h2>Comparison for ',str_to_upper(idkey),'</h2>'))
    print(com_sum0,format="html")
    pipe1 <- paste0("sed -i 's/<!--generated by print.comparedf-->/<tr>",
           html_com_sum,
           "<\\/tr><!--generated by print.comparedf-->",
           html_end,
           "/' ",
           out) %>% pipe()
    scan(pipe1)
    close(pipe1)
  } else {
    #capture.output()
    tempDir <- tempfile()
    dir.create(tempDir)
    temp_file <- file.path(tempDir, "print_comparedf.html")
    sink(temp_file, append=TRUE)
    cat(html_head)

    cat(paste0('<hr/><h2>Comparison for ',str_to_upper(idkey),'</h2>'))
    print(com_sum0,format="html")
    viewer <- getOption("viewer")
    viewer(temp_file)
  }
  for(i in seq_len(sink.number())) sink()
}












#' Set variable attributes like SAS dataset
#'
#' Sets attributes from input dataset as per metadata, to create ADaM dataset.
#' The metadata must be a SAS dataset generated by %opImportPDSv2 or a R data frame modified from it.
#' It might change the order, length, label, format of variables, the label of
#' dataset, the sorting order of observations.
#' See more details in /vob/CSRTRAIN/CSRTRAINCN/csr_20/util/opToolUserGuide.docx
#'
#' @param indata    Input R data frame
#' @param domain    Name of ADaM domain. Case insensitive
#' @param metadata  SAS dataset generated by %opImportPDS, or R data frame modified from it
#'        Allowable value:
#'	      library.data.ext library is from list st.
#'                         data is a data file name.
#'                         ext is optional, a file name extension.
#'	      dataframe        a R data frame modified from the SAS metadata
#'
#' @return A data frame formatted
#'
#' @examples
#' #Create adae R data frame from the user generated R data frame final_ae
#' adae <- set_attr(indata=final_ae, domain=adae)
#' @export
set_attr <- function(indata,domain,metadata=rprtdsm.opmetadata) {
  # developed by Carlos
  metadata1 <- deparse(substitute(metadata))
  domain1 <- str_to_upper(deparse(substitute(domain)))
  names(indata) <- str_to_upper(names(indata))
  
  #read in metadata data
  if (str_detect(metadata1,r'(^(\w+)\.(\w+)(\.\w+)?$)')) {
    expr1 <- sprintf("meta1 <- read_df(%s)",metadata1)
    eval(parse(text=expr1))
  } else if (exists(metadata1)) {
    try(if(!is.data.frame(metadata))
      stop(paste0(metadata1, ' from parameter metadata is neither like library.sasdata nor a data frame.')))
    meta1<-metadata
  } else {
    stop(paste0(metadata1, ' from parameter metadata is neither like library.sasdata nor a data frame.'))
  }
  
  #manipulate metadata
  meta1 <- meta1 %>% mutate(dsname=str_to_upper(dsname),
                            format=str_to_upper(str_replace(format,'(?<!\\.)$','.')))
  if (nrow(filter(meta1,dsname==domain1))==0) stop(sprintf("No record for domain %s.",domain1))
  com_var_in1 <- filter(meta1,dsname==domain1)$com_var_in[1] %>% str_to_upper()
  regex1 <- sprintf("\\b%s\\b",com_var_in1) %>% regex(ignore_case=TRUE)
  dslabel1 <- filter(meta1,dsname==domain1)$dslabel[1]
  uid1 <- filter(meta1,dsname==domain1)$uid[1] %>% str_to_upper()
  meta2 <- meta1 %>% filter(dsname==domain1|
                              (com_var_in1 %in% c("ALL","YES","Y") & !(com_var %in% c('','NO')))|
                              (!(com_var_in1 %in% c("NO","")) & str_detect(com_var,regex('\\b(all|yes|y)\\b',ignore_case=TRUE)))|
                              (!(com_var_in1 %in% c("ALL","YES","Y","NO","")) & str_detect(com_var,regex1)))
  meta3 <- meta2 %>% mutate(var_order=1:nrow(meta2)+if_else(dsname==domain1,1e5,0),
                            var=str_to_upper(var)) %>%
    select(dsname,var,label,type,length,format,var_order) %>%
    group_by(var) %>% filter(var_order==min(var_order)) %>% ungroup()
  meta3[meta3$var=='SUBJID','var_order'] <- meta3[meta3$var=='USUBJID','var_order']+0.1
  meta3 <- modify(meta3,function(x) `attributes<-`(x,NULL))
  
  #check if indata aligns with metadata
  indata_content1 <- summary.default(indata) %>% as.data.frame() %>%
    mutate(var=as.character(Var1)) %>%
    group_by(Var1) %>% spread(key=Var2,value=Freq) %>% ungroup() %>% select(-Length) %>%
    right_join(meta3,by="var")
  
  indata_miss <- filter(indata_content1,is.na(Var1))['var'] %>% unlist()
  if (length(indata_miss)>0) warning(paste0(
    "Some variables in metadata, but not in indata:\n",str_c(indata_miss,collapse=" ")))
  indata_content2 <- filter(indata_content1,!is.na(Var1)) %>%
    mutate(type_align=str_to_lower(paste0(substring(Mode,1,1),type)) %in% c('cc','cchar','ctext','nn','nnum'),
           format_align=str_detect(paste0(Class,'#',format),'^(-none-#[\\$\\d\\.\\s]+|Date#DATE9\\.|POSIXct#DATETIME19\\.|hms#TIME[0-9]?\\.)$'))
  
  if (!all(indata_content2$type_align)) warning(paste0(
    "Variable type in indata does not align with metadata:\n",
    "Variable\tType\tMetadata\n",
    indata_content2 %>% filter(!type_align) %>% transmute(paste0(var,"\t",Mode,"\t",type)) %>%
      unlist() %>% str_c(collapse="\n")
  ))
  
  if (!all(indata_content2$format_align)) warning(paste0(
    "Variable class in indata does not align with metadata format.\n",
    "  If metadata format is DATE9, variable class should be Date.\n",
    "  If metadata format is DATETIME19, variable class should be POSIXct.\n",
    "  If metadata format is TIME*, variable class should be hms.\n",
    "Variable\tClass\tFormat\n",
    indata_content2 %>% filter(!format_align) %>% transmute(paste0(var,"\t",Class,"\t",format)) %>%
      unlist() %>% str_c(collapse="\n")
  ))
  
  #sort records
  uid2 <- uid1 %>% str_replace_all(sprintf('\\b(%s|DESCENDING)\\b\\s?',str_c(indata_content2$var,collapse='|')),'') %>% str_trim()
  if (uid2!='') {
    warning(sprintf("Variable %s in metadata UID(Sort Order), but not in indata.",uid2))
    uid1 <- uid1 %>% str_replace_all(sprintf('\\b(%s)\\b\\s?',str_replace_all(uid2,"\\s","|")),'')
  }
  if (uid1!='') {
    uid11 <- uid1 %>% str_replace_all("\\bDESCENDING\\s+","") %>% str_replace_all("\\s",",indata$")
    uid12 <- uid1 %>% str_replace_all("\\bDESCENDING\\s+","@") %>%
      str_replace_all("(?<!@)\\b\\w+","F") %>% str_replace_all("@\\w+","T") %>%
      str_replace_all("\\s+",",")
    expr1 <- sprintf("order(indata$%s,method='radix',decreasing=c(%s),na.last=FALSE)",uid11,uid12)
    uid3n <- eval(parse(text=expr1))
    indata <- indata[uid3n,]
  }
  
  #set attributes
  indata_content3 <- indata_content2 %>%
    mutate(format2={format[str_detect(format,'DATE|TIME')]<-str_replace(str_subset(format,'DATE|TIME'),"\\.$","")
    format[str_detect(format,'^[\\$\\d\\.\\s]+$')]<-NA
    format},
    tzone=if_else(str_detect(format2,'DATETIME19'),'UTC',NA_character_),
    units=if_else(str_detect(format2,'TIME5'),'secs',NA_character_)) %>%
    arrange(var_order)
  
  indata2 <- indata %>% select(indata_content3$var)
  indata2 <- modify2(indata2,indata_content3$label,~ `attr<-`(.x,'label',.y))
  indata2 <- modify2(indata2,indata_content3$format2,~ `attr<-`(.x,'format.sas',if(is.na(.y)) NULL else .y ))
  #indata2 <- modify2(indata2,indata_content3$tzone,~ `attr<-`(.x,'tzone',if(is.na(.y)) NULL else .y ))
  #indata2 <- modify2(indata2,indata_content3$units,~ `attr<-`(.x,'units',if(is.na(.y)) NULL else .y ))
  attr(indata2,'label') <- dslabel1
  
  indata2
}










*  DATE CREATED  : 28JUL2025
*  AUTHOR        : YAOAI1

*  DESCRIPTION   : Table 14.2-1.9.1Supplementary estimand 3 - Repeated measures (MMRM) analysis of the change from baseline in eGFR (mL/min/1.73m2) to 24 months – Main study population

*  PLATFORM      : (see SAS log file)
*  SAS VERSION   : (see SAS log file)

*  MACROS CALLED : <type here>
*  INPUT         : adsl,adfacit
*  OUTPUT        : t142_1_9_01.rtf, t142_1_10_01.rtf

*  MODIFICATIONS : [x.xx] dd-mmm-yy, 5-2-1 id, brief description
* (see file management system for changes) 
****************************************************************/


data _null_;
  if libref('analysis') then call execute('%nrstr(%autorun;)');
run;

/*%let sysparm = PTL2012_SP2_ -log 't_mmrm_upcr_pr.sas_PTL2012.log';*/
proc format;
  value $label
  "LNP023 200 mg"="LNP023 200 mg bid"
  "Placebo"="Placebo";
run;

%macro generatetfl(dat=,pop=,cat=,id=,report=);

data ana1;
  set analysis.&dat.;
  where &pop.="Y" and acat1=&cat. and avisit ne "Baseline" /*and 1<=impnum<=10*/;
run;


proc sort data=ana1; by impnum trt01pn; run;

ods output LSMeans=lsm diffs=diff covparms=covp convergencestatus=convtest;
proc mixed data=ana1 METHOD=REML order=internal;
  by impnum;
  class trt01pn (ref="2") avisitn subjid strval1 strval2 strval3;
  model chg = trt01pn avisitn strval1 strval2 strval3 base trt01pn*avisitn avisitn*base/fullx ddfm=kr;  
  repeated avisitn/subject=subjid type=un;
  lsmeans trt01pn*avisitn/cl COV diff E OM at means alpha=0.05;
run;

/*results 1: Difference between treatment goup*/

proc sort data=diff; 
  by trt01pn avisitn _trt01pn _avisitn; 
/*  where trt01pn ne _trt01pn and avisitn=_avisitn;*/
run;
ods output ParameterEstimates = diff_mi /*(keep = trt01pn avisitn estimate stderr lclmean uclmean probt)*/;
proc mianalyze data=diff;
	by trt01pn avisitn _trt01pn _avisitn;
	ModelEffects ESTIMATE;
	stderr stderr;
run;
data diff_mi2;
  set diff_mi (rename = (probt = probt_));
  if estimate > 0 then probt = probt_/2;
  else if estimate < 0 then probt = 1-probt_/2;
run;

/*results 2: Mean effect for each treatment goup*/
proc sort data=lsm; 
  by avisitn trt01pn; 
/*  where trt01pn ne _trt01pn and avisitn=_avisitn;*/
run;
ods output ParameterEstimates = lsm_mi /*(keep = trt01pn avisitn estimate stderr lclmean uclmean probt)*/;
proc mianalyze data=lsm;
	by avisitn trt01pn;
	ModelEffects ESTIMATE;
	stderr stderr;
run;

/*Calculation of geometric means*/
data lsm2;
set lsm_mi;
length chg_m $100.;
chg_m=strip(put(round(Estimate,0.001),10.3)) || " (" || strip(put(round(LCLMean,0.001),10.3)) || ", " || strip(put(round(UCLMean,0.001),10.3)) || ")";
keep avisitn trt01pn chg_m Estimate LCLMean UCLMean;
run;
/*Calculation of geometric mean ratio to placebo*/
data diff2;
set diff_mi2;
length chg_m_diff pval $100.;
where avisitn=_avisitn;
chg_m_diff=strip(put(round(Estimate,0.001),10.3)) || " (" || strip(put(round(LCLMean,0.001),10.3)) || ", " || strip(put(round(UCLMean,0.001),10.3)) || ")";
/*reduce=strip(put(1-geo_est_ratio,10.3)) || " (" || strip(put(1-geo_lower_ratio,10.3)) || ", " || strip(put(1-geo_upper_ratio,10.3)) || ")";*/
/*reduce=strip(put(100-geo_est_ratio*100,10.3)) || " (" || strip(put(100-geo_upper_ratio*100,10.3)) || ", " || strip(put(100-geo_lower_ratio*100,10.3)) || ")";*/
if . < PROBT <= 0.0001 then pval = "<.0001";
else if . < PROBT => 0.9999 then pval = ">0.9999";
else pval = strip(put(round(PROBT,0.0001),10.4));
pvalN=PROBT;
Estimate_diff=Estimate;
LCLMean_diff=LCLMean;
UCLMean_diff=UCLMean;
keep avisitn trt01pn chg_m_diff pval pvaln Estimate_diff LCLMean_diff UCLMean_diff;
run;


proc sql noprint;
  create table count as
  select count(distinct usubjid) as bigN, trt01pn, trt01p
  from ana1
  group by trt01pn, trt01p;
  create table count2 as
  select count(distinct usubjid) as nobs, avisitn, avisit, trt01pn, trt01p
  from ana1
  where dtype in ("" "TP")
  group by avisitn, avisit, trt01pn, trt01p;
quit;

data final;
length label $100.;
  merge count2 lsm2 diff2;
  by avisitn trt01pn;
/*  if avisitn<=206;*/
/*  label=put(trt01p,$label.);*/
  label=trt01p;
  if avisitn ne 211 then call missing (pval);
run;
proc sql noprint;
  create table final2 as
  select a.*, bigN
  from final a left join count b on
  a.trt01pn=b.trt01pn
  order by avisitn, avisit, trt01pn, trt01p;
quit;

data rprteff.anstat_&id;
	set final2;

	if pval eq "" then pvaln=.;
run;

/********************************************************************
   Output display
********************************************************************/
  %let _std_indset           = final2;
 
/* Define List of variables in Column Statement */
  %let _std_column           = avisit label bigN nobs chg_m ("LNP023 200mg b.i.d. vs Placebo" chg_m_diff pval);
  %let _std_defaultdset       = analysis.defaults;

/* Pseudodefine */
   %let avisit             = 11 ~ l ~l~ "Time point";
   %let label             = 20 ~ l ~l~ "Treatment";
   %let bigN               = 5 ~ c ~c~ "N";
   %let nobs                  = 5 ~ c ~c~ "n";
   %let chg_m              = 28 ~ c ~c~ "Adjusted mean@%sysfunc(repeat(%sysfunc(byte(160)),2))(95% CI)";
   %let chg_m_diff        = 28 ~ c ~c~ "Adjusted mean difference@%sysfunc(repeat(%sysfunc(byte(160)),2))(95% CI)";
   %let pval               = 7 ~ c ~c~ "1-sided@p-value";

/********************************************************************
   Sorting, Page break and report settings
********************************************************************/
   %let _STD_SORT_column        = avisitn trt01pn;
/*   %let _std_colwidth           = 12;*/
   %let _std_skip               = ;
   %let _std_norepeat           = ;
   %let _std_pagebreak		= ;								
   %let _std_norepeat     = avisit;


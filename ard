proc mianalyze data=miest_j2rd; 
ods output ParameterEstimates=combined_estimates_j2rd;
modeleffects  Estimate;
stderr StdErr;
by Label;
run;



data lsm1(drop=lsmdiff pval) lsm2(drop=label lsm);
set combined_estimates_j2rd(rename = (probt = probt_));
length lsm lsmdiff pval $100.;
if label="eGFR slope difference (year)" then do; 
  lsmdiff=strip(put(round(estimate,0.001),10.3)) || " (" || strip(put(round(LCLMean,0.001),10.3)) || ", " || strip(put(round(UCLMean,0.001),10.3)) || ")"; 
  if estimate > 0 then probt = probt_/2;
  else if estimate < 0 then probt = 1-probt_/2;
  if . < PROBT =< 0.0001 then pval = "<0.0001";
  else if . < PROBT => 0.9999 then pval = ">0.9999";
  else pval = strip(put(round(probt,0.0001),best.));
end;
  else lsm=strip(put(round(estimate,0.001),10.3)) || " (" || strip(put(round(StdErr,0.001),10.3)) || ")";
  if label ne "eGFR slope difference (year)" then output lsm1;
  else output lsm2;
keep label lsm lsmdiff pval estimate stderr lclmean uclmean probt;
run;
proc sql noprint;
  create table lsm3 as
  select a.label, a.lsm, a.estimate, a.stderr, a.lclmean, a.uclmean, b.lsmdiff, b.pval,b.probt as pvaln
  from lsm1 a, lsm2 b;
quit;



   Output file management
********************************************************************/

/* ODS output type */
%Let _std_indtflow=0;
%let _std_output_post_in             = WCB;
%let _std_wcb_no_lines_page          = 24;
%let _std_desc_output_type           = Table;
%let _std_orientation                = LANDSCAPE;

%let _std_ods_type=RTF;
%let _std_ods_out = %sysfunc(pathname(RPRTEFF))/&report..rtf;
/*%let _std_saveout = REPORT;*/
%let _std_rtf_output = %sysfunc(pathname(RPRTEFF))/&report..rtf;
/** Add end   ************************************************************;*/
/*%let _std_saveout = rprtdra.anstat_PTL0171;*/

*--------------------------------*;
*-- Section 3:  Produce Output --*;
*--------------------------------*;
%_std_readparam(deliv_id=&id, csvfilepath= %sysfunc(pathname(RAUTIL))/TrakData.csv);

%std_onc_dev_listing;

%symdel _std_output_number;
%mend;

